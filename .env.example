# ═══════════════════════════════════════════════════════════════
# ÉLISSIA v8 — Configuration complète
# Renomme ce fichier en .env
# C:\Users\laure\Desktop\Copine\Elissia\Elissia\.env
# ═══════════════════════════════════════════════════════════════

# ── SECRETS ──────────────────────────────────────────────────────
APP_ENCRYPTION_KEY=
AUDIT_SECRET=
BACKUP_ENCRYPTION_KEY=

# ── SERVEUR ──────────────────────────────────────────────────────
PORT=3000
APP_NAME=Elissia
NODE_ENV=production

# ── BASE DE DONNÉES ───────────────────────────────────────────────
# UNE SEULE ligne DATABASE_PATH — pointe vers ton ancienne DB
DATABASE_PATH=./elissia.db
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=14

# ── MODE LLM ─────────────────────────────────────────────────────
MODE=cloud

# ── OPENROUTER — LLM cloud ───────────────────────────────────────
# Recolle ta clé ici
OPENROUTER_KEY=
CLOUD_MODEL=sao10k/l3-lunaris-8b
CLOUD_VISION_MODEL=meta-llama/llama-3.2-11b-vision-instruct

# ── OLLAMA LOCAL (si MODE=local) ─────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=elissia
OLLAMA_EMBED_MODEL=nomic-embed-text
VISION_MODEL=ramitmitra/qwen3.5-uncensored-9b-baburao

# ── COMFYUI — Génération images locale ───────────────────────────
COMFY_URL=http://127.0.0.1:8188
# Ton modèle téléchargé :
COMFY_MODEL=z_image_turbo_bf16.safetensors

# ── FAL.AI — Optionnel ────────────────────────────────────────────
# Recolle ta clé ici si tu veux l'utiliser en fallback
FAL_API_KEY=ea65c1fa-9aa3-42f1-85fd-6f97baa1063f:0cca62c8cac85ab2611bb145848f2da8

# ── CIVITAI — Optionnel ───────────────────────────────────────────
# Recolle ta clé ici (civitai.com → Account → API Keys)
CIVITAI_API_KEY=
CIVITAI_MODEL_REALISTIC=urn:air:sdxl:checkpoint:civitai:133005@1759168
CIVITAI_MODEL_ARTISTIC=urn:air:illustrious:checkpoint:civitai:827184@2883731
CIVITAI_MODEL_EXPLICIT=urn:air:pony:checkpoint:civitai:257749@290640
CIVITAI_MODEL_VIDEO=urn:air:wan:video:civitai:580751@649226

# ═══════════════════════════════════
# API EXTERNES (images, web, voix)
# ═══════════════════════════════════
PERPLEXITY_API_KEY=ppl

# ── SESSION ───────────────────────────────────────────────────────
SESSION_DAYS=14
COOKIE_SECURE=false

# ── INSCRIPTION ───────────────────────────────────────────────────
ALLOW_REGISTRATION=true
# INVITE_CODE=033199

# ── PLUGINS ───────────────────────────────────────────────────────
PLUGINS_ENABLED=true

# ── PIPER TTS LOCAL — Optionnel ──────────────────────────────────
# PIPER_BIN=C:\Users\laure\AppData\Local\piper\piper.exe
# PIPER_MODEL=C:\Users\laure\AppData\Local\piper\fr_FR-siwis-medium.onnx
# PIPER_VOICE_NAME=Voix française locale

