# ═══════════════════════════════════════════════════
#   ÉLISSIA — Configuration (.env)
#   Copie ce fichier en ".env" et remplis tes valeurs
# ═══════════════════════════════════════════════════

# ── Serveur ──────────────────────────────────────
PORT=3000

# ── Sécurité (OBLIGATOIRE - génère des clés aléatoires) ──
# Génère avec : node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_ENCRYPTION_KEY=CHANGE_MOI_cle_base64_32_octets
SESSION_SECRET=CHANGE_MOI_secret_aleatoire_long

# ── Base de données ──────────────────────────────
DATABASE_PATH=./elissia.db

# ── Ollama (IA locale) ───────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=elissia
EMBED_MODEL=nomic-embed-text
# Modèle de vision (pour qu'elle voie les photos/webcam)
# ⚠️ llava est CENSURÉ (refuse le nu). Pour la webcam intime, utilise un modèle vision NON censuré :
#   ollama pull ramitmitra/qwen3.5-uncensored-9b-baburao   (9B, vision, non censuré - recommandé)
# Puis mets son nom ci-dessous. llava:13b reste OK pour du non-intime.
VISION_MODEL=llava:13b

# ── Civitai (génération d'images) ────────────────
# Récupère ta clé sur https://civitai.com/user/account
CIVITAI_API_KEY=CHANGE_MOI_ta_cle_civitai
# Modèles (optionnel - valeurs par défaut fournies)
CIVITAI_MODEL_REALISTIC=urn:air:sdxl:checkpoint:civitai:133005@1759168
CIVITAI_MODEL_ARTISTIC=urn:air:illustrious:checkpoint:civitai:827184@2883731
CIVITAI_MODEL_EXPLICIT=urn:air:pony:checkpoint:civitai:257749@290640

# ── Piper TTS (voix locale, optionnel) ───────────
# Chemin vers l'exécutable Piper si tu veux une voix locale HD
# PIPER_BIN=C:\piper\piper.exe
# PIPER_VOICE=fr_FR-siwis-medium
